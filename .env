# Mode
# Use `demo` for the local mock runner and safer setup work.
# Switch to `mainnet` only after filling the live trading fields below.
NETWORK=demo
DEMO_MODE=true

# Entry market
# MARKET_ID is required by src/index.ts.
# BTC Up or Down daily market (more stable than 5min)
MARKET_ID=bitcoin-up-or-down-on-may-14-2026

# Wallet
# Keep the placeholder for demo. Replace with a real 0x... private key only for live trading.
PRIVATE_KEY=your_demo_private_key_here

# Bot settings
INITIAL_CAPITAL_USDC=500
SPREAD_BPS=200
SPREAD_BPS_MEDIUM_EDGE=300
SPREAD_BPS_HIGH_EDGE=500
BASE_ORDER_SIZE=10
MEDIUM_EDGE_ORDER_SIZE=15
HIGH_EDGE_ORDER_SIZE=20
MIN_EDGE_TO_TRADE=0.04
MEDIUM_EDGE_THRESHOLD=0.06
HIGH_EDGE_THRESHOLD=0.08
MAX_DAILY_DRAWDOWN_PCT=8
STRIKE_PRICE=65000
TARGET_WINDOW_START=30
TARGET_WINDOW_END=270
DEMO_DURATION_MS=86400000
DASHBOARD_PORT=3000

# Live Polymarket CLOB settings
# These are ignored by the local demo runner but required for real order placement.
POLYMARKET_CLOB_URL=https://clob.polymarket.com
WS_URL=wss://ws.polymarket.com
CHAIN_ID=137
SIGNATURE_TYPE=0
TOKEN_ID=
FUNDER_ADDRESS=
TICK_SIZE=0.01
NEG_RISK=false

COMPOUNDING_ENABLED=true
COMPOUNDING_STRATEGY=tiered
COMPOUNDING_REINVEST_PCT=50

# Tier targets
TIER1_CAPITAL_TARGET=5000
TIER1_REINVEST_PCT=100

TIER2_CAPITAL_TARGET=25000
TIER2_REINVEST_PCT=50

TIER3_CAPITAL_TARGET=100000
TIER3_REINVEST_PCT=30

# Notes for live trading
# 1. Set DEMO_MODE=false
# 2. Set NETWORK=mainnet
# 3. Fill MARKET_ID, TOKEN_ID, FUNDER_ADDRESS, and PRIVATE_KEY

# Backtest mode (uses real market data, simulated orders)
# Run: npm run backtest
# Note: Set MARKET_ID to a real Polymarket market (e.g., BTC crypto market)
BACKTEST_MODE=true
BACKTEST_DURATION_MINUTES=60
