# Mode
# Use `demo` for the local mock runner and safer setup work.
# Switch to `mainnet` only after filling the live trading fields below.
NETWORK=demo
DEMO_MODE=true

# Entry market
# MARKET_ID is required by src/index.ts.
MARKET_ID=demo-btc-5m

# Wallet
# Keep the placeholder for demo. Replace with a real 0x... private key only for live trading.
PRIVATE_KEY=your_demo_private_key_here

# Bot settings
INITIAL_CAPITAL_USDC=500
SPREAD_BPS=20
SPREAD_BPS_MEDIUM_EDGE=24
SPREAD_BPS_HIGH_EDGE=30
BASE_ORDER_SIZE=10
MEDIUM_EDGE_ORDER_SIZE=15
HIGH_EDGE_ORDER_SIZE=20
MIN_EDGE_TO_TRADE=0.04
MEDIUM_EDGE_THRESHOLD=0.06
HIGH_EDGE_THRESHOLD=0.08
MAX_DAILY_DRAWDOWN_PCT=8
STRIKE_PRICE=65000
TARGET_WINDOW_START=255
TARGET_WINDOW_END=295
DEMO_DURATION_MS=86400000
DASHBOARD_PORT=3000

# Live Polymarket CLOB settings
# These are ignored by the local demo runner but required for real order placement.
POLYMARKET_CLOB_URL=https://clob.polymarket.com
WS_URL=wss://ws.polymarket.com
CHAIN_ID=137
SIGNATURE_TYPE=0
TOKEN_ID=
FUNDER_ADDRESS=
TICK_SIZE=0.01
NEG_RISK=false

# Notes for live trading
# 1. Set DEMO_MODE=false
# 2. Set NETWORK=mainnet
# 3. Fill MARKET_ID, TOKEN_ID, FUNDER_ADDRESS, and PRIVATE_KEY
